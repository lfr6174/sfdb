# =============================================================================
# Backend environment variables — copy this file to `.env` and fill in values.
#   cp .env.example .env
#
# `.env` is git-ignored and read by python-decouple (see config/settings/).
# Only the variables that the settings actually read are listed here.
# =============================================================================

# -----------------------------------------------------------------------------
# Which settings module to load.
#   - Local dev:  config.settings.dev   (DEBUG=True,  SQLite)
#   - Production: config.settings.prod  (DEBUG=False, PostgreSQL)
# NOTE: DEBUG is NOT an env variable — it is hard-coded per settings module.
#       Setting DEBUG=... in this file does nothing; choose the module instead.
# manage.py defaults to config.settings.dev, so locally you can leave this unset.
# -----------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.dev

# -----------------------------------------------------------------------------
# Required in ALL environments (base.py)
# -----------------------------------------------------------------------------

# Django cryptographic secret. MUST be unique and secret in production.
# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=change-me-to-a-random-50-char-string

# Path prefix for the Django admin (trailing slash required).
# Locally this can stay as admin/. In production, set it to something
# non-guessable (e.g. a random word) — prod.py REQUIRES it with no fallback.
ADMIN_URL=admin/

# =============================================================================
# PRODUCTION ONLY (config/settings/prod.py)
# The variables below are read only when DJANGO_SETTINGS_MODULE=config.settings.prod.
# The app will fail to boot in production if any required one is missing.
# Values are comma-separated lists where noted.
# =============================================================================

# Comma-separated hostnames Django will serve (no scheme, no trailing slash).
# Example: ALLOWED_HOSTS=api.example.com,example.com
ALLOWED_HOSTS=api.example.com

# Comma-separated origins (WITH scheme) allowed to call the API via CORS.
# This is your FRONTEND origin(s), e.g. the Vercel site.
# Example: CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=https://example.com

# Comma-separated origins (WITH scheme) trusted for CSRF (admin login, etc.).
# Usually your API/admin domain(s).
# Example: CSRF_TRUSTED_ORIGINS=https://api.example.com
CSRF_TRUSTED_ORIGINS=https://api.example.com

# PostgreSQL connection string (parsed by dj-database-url).
# Example: DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgres://user:password@host:5432/dbname

# Force HTTPS redirects. Defaults to True; set to False only if TLS is
# terminated upstream and the redirect would cause a loop.
# SECURE_SSL_REDIRECT=True
