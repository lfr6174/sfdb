# =============================================================================
# Frontend environment variables.
#
# There are TWO separate kinds of variable here — do not confuse them:
#
#   1. VITE_* — read at BUILD time and baked into the static bundle.
#      Vite loads these from .env files automatically per mode:
#        .env.development  (used by `npm run dev`)
#        .env.production   (used by `npm run build`)
#      Copy this file to `.env` for a local override:  cp .env.example .env
#
#   2. API_BASE_URL — read at RUNTIME by the Vercel Edge Functions
#      (api/render.ts, api/sitemap.ts). It is NOT a VITE_ variable and is
#      NOT read from these files in production. Set it in the Vercel
#      dashboard (Project → Settings → Environment Variables).
# =============================================================================

# --- 1. Build-time (Vite) -----------------------------------------------------
# Base URL of the backend REST API, including the /api suffix, no trailing slash.
# Local dev points at the Django dev server:
VITE_API_BASE_URL=http://127.0.0.1:8000/api
# Production example (set in .env.production):
#   VITE_API_BASE_URL=https://api.example.com/api

# --- 2. Runtime (Vercel Edge Functions) --------------------------------------
# Set this in the Vercel dashboard, NOT in a committed file. Same value as the
# production VITE_API_BASE_URL above (backend API base, incl. /api):
#   API_BASE_URL=https://api.example.com/api
